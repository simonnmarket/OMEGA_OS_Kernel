{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProvaRastreavelPSA",
  "type": "object",
  "required": [
    "proof_id",
    "req_id",
    "doc_ref",
    "fase",
    "titulo_curto",
    "artefacto_obrigatorio",
    "comando_ou_predicado",
    "resultado_esperado",
    "resultado_actual",
    "veredito",
    "git_head",
    "ts_utc"
  ],
  "properties": {
    "proof_id": { "type": "string", "pattern": "^PRF-[A-Z0-9]+-\\d{8}-\\d{3}$" },
    "req_id": { "type": "string", "pattern": "^REQ-[A-Z]+-\\d{3}$" },
    "doc_ref": { "type": "string" },
    "fase": { "type": "string" },
    "titulo_curto": { "type": "string", "maxLength": 120 },
    "artefacto_obrigatorio": { "type": "string" },
    "comando_ou_predicado": { "type": "string" },
    "resultado_esperado": { "type": "string" },
    "resultado_actual": { "type": "string" },
    "veredito": { "type": "string", "enum": ["PASS", "FAIL"] },
    "bloqueador": { "type": ["string", "null"] },
    "git_head": { "type": "string", "minLength": 40, "maxLength": 40 },
    "ts_utc": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
  },
  "additionalProperties": false
}

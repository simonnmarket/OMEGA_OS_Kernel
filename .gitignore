# === OMEGA OS Kernel — .gitignore ===

# Dados brutos OHLCV (muito grandes para git, manter local)
OHLCV_DATA/
grafico_linha/
grafico_candle/

# Artefatos de output grandes (>5MB) — manter em disco local
audit/**/harmonic_events_*.json
audit/**/harmonic_events_*.csv

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Logs de execução pesados
*.log

# Node / Frontend
node_modules/
dist/
build/
.next/

# Ambientes
.env
.env.local
.venv/
venv/

# IDE
.cursor/
.vscode/
*.suo
*.user

# OS
Thumbs.db
.DS_Store
